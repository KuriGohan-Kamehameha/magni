<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/retro_shell">

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout
            android:id="@+id/webContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/retro_inner" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <com.ayn.magni.ui.CursorOverlayView
        android:id="@+id/cursorOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/loadProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_gravity="top"
        android:contentDescription="@string/accessibility_progress_bar"
        android:indeterminate="false"
        android:max="100"
        android:progressBackgroundTint="@color/retro_progress_track"
        android:progressTint="@color/retro_orange" />

    <TextView
        android:id="@+id/tabInfoText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/retro_button_normal"
        android:contentDescription="@string/accessibility_tab_info"
        android:paddingHorizontal="7dp"
        android:paddingVertical="3dp"
        android:textColor="@color/retro_text"
        android:textSize="10sp"
        android:visibility="gone" />

    <View
        android:id="@+id/toolbarHandle"
        android:layout_width="72dp"
        android:layout_height="16dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="8dp"
        android:background="@drawable/toolbar_handle_background"
        android:clickable="true"
        android:contentDescription="@string/toolbar_handle_description"
        android:focusable="true" />

    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:layout_gravity="bottom"
        android:background="@color/retro_toolbar"
        android:orientation="vertical"
        android:paddingStart="5dp"
        android:paddingTop="5dp"
        android:paddingEnd="5dp"
        android:paddingBottom="5dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <Button
                android:id="@+id/backButton"
                style="@style/RetroToolbarButton"
                android:layout_marginEnd="3dp"
                android:contentDescription="@string/accessibility_back_button"
                android:text="@string/button_back"
                android:visibility="gone" />

            <Button
                android:id="@+id/forwardButton"
                style="@style/RetroToolbarButton"
                android:layout_marginEnd="3dp"
                android:contentDescription="@string/accessibility_forward_button"
                android:text="@string/button_forward"
                android:visibility="gone" />

            <Button
                android:id="@+id/reloadButton"
                style="@style/RetroToolbarButton"
                android:layout_marginEnd="3dp"
                android:contentDescription="@string/accessibility_reload_button"
                android:text="@string/button_reload"
                android:visibility="gone" />

            <Button
                android:id="@+id/urlButton"
                style="@style/RetroToolbarButton"
                android:layout_height="match_parent"
                android:layout_marginEnd="0dp"
                android:contentDescription="@string/accessibility_url_button"
                android:text="@string/url_bar_placeholder"
                android:textAllCaps="false"
                android:textSize="13sp" />

            <Button
                android:id="@+id/homeButton"
                style="@style/RetroToolbarButton"
                android:contentDescription="@string/accessibility_home_button"
                android:text="@string/button_home"
                android:visibility="gone" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/tabsButton"
                    style="@style/RetroToolbarCompactButton"
                    android:layout_marginEnd="3dp"
                    android:contentDescription="@string/accessibility_tabs_button"
                    android:text="@string/button_tabs" />

                <Button
                    android:id="@+id/newTabButton"
                    style="@style/RetroToolbarCompactButton"
                    android:layout_marginEnd="3dp"
                    android:contentDescription="@string/accessibility_new_tab_button"
                    android:text="@string/button_new_tab" />

                <Button
                    android:id="@+id/settingsButton"
                    style="@style/RetroToolbarCompactButton"
                    android:layout_marginEnd="3dp"
                    android:contentDescription="@string/accessibility_settings_button"
                    android:text="@string/button_settings" />

                <Button
                    android:id="@+id/downloadsButton"
                    style="@style/RetroToolbarCompactButton"
                    android:layout_marginEnd="3dp"
                    android:contentDescription="@string/accessibility_downloads_button"
                    android:text="@string/button_downloads" />

                <Button
                    android:id="@+id/desktopButton"
                    style="@style/RetroToolbarCompactButton"
                    android:layout_marginEnd="3dp"
                    android:contentDescription="@string/accessibility_desktop_button"
                    android:text="@string/button_desktop" />

                <Button
                    android:id="@+id/readerButton"
                    style="@style/RetroToolbarCompactButton"
                    android:layout_marginEnd="3dp"
                    android:contentDescription="@string/accessibility_reader_button"
                    android:text="@string/button_reader" />

                <Button
                    android:id="@+id/zoomOutButton"
                    style="@style/RetroToolbarCompactButton"
                    android:layout_marginEnd="3dp"
                    android:contentDescription="@string/accessibility_zoom_out_button"
                    android:text="@string/button_zoom_out" />

                <Button
                    android:id="@+id/zoomInButton"
                    style="@style/RetroToolbarCompactButton"
                    android:contentDescription="@string/accessibility_zoom_in_button"
                    android:text="@string/button_zoom_in" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

</FrameLayout>
