<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="4dp"
    android:background="@drawable/retro_button_normal"
    android:orientation="vertical"
    android:padding="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/retro_text"
            android:textSize="11sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/openButton"
            android:layout_width="52dp"
            android:layout_height="28dp"
            android:background="@drawable/retro_button_background"
            android:text="@string/settings_open"
            android:textColor="@color/retro_text"
            android:textSize="10sp" />

        <Button
            android:id="@+id/deleteButton"
            android:layout_width="36dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/retro_button_background"
            android:text="@string/settings_delete"
            android:textColor="@color/retro_text"
            android:textSize="10sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/urlText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/retro_muted"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/timeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/retro_muted"
        android:textSize="10sp" />

</LinearLayout>
